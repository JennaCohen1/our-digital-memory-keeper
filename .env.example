# Supabase (required for auth and data)
# From Supabase Dashboard: Settings -> API -> Project URL and anon public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth: configure in Supabase Dashboard (Authentication -> Providers -> Google)
# Optional: only needed if you add Google-specific features (e.g. Drive export) in the app
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
