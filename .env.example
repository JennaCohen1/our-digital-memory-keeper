# Google OAuth (required for Sign in with Google)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Use "External" user type so anyone with a Google account can sign in.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional: backend URL for saving to central Google Drive (when you add the server)
# VITE_API_URL=http://localhost:3001
